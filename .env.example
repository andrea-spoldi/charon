# Charon - Environment Variables
# Copy this file to .env and fill in the values

# Charon log level (trace, debug, info, warn, error)
# Takes precedence over RUST_LOG. Logs are written to ~/.charon/charon.log
CHARON_LOG_LEVEL=info

# Rust log level — fallback if CHARON_LOG_LEVEL is not set
RUST_LOG=info

# Tauri dev host (optional, for mobile dev)
# TAURI_DEV_HOST=
